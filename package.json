{
  "name": "bookbat-workspace",
  "version": "0.7.3",
  "private": true,
  "type": "module",
  "scripts": {
    "certs:generate": "node scripts/generate-dev-certs.mjs",
    "data:sync": "node scripts/sync-library-data.mjs",
    "data:sync:dummy": "LIBRARY_SOURCE_FILE=data/library.dummy.json node scripts/sync-library-data.mjs",
    "data:apply": "node scripts/apply-library-data.mjs",
    "dev": "pnpm dev:webapp",
    "dev:webapp": "pnpm data:sync && pnpm --filter @bookbat/webapp dev",
    "dev:webapp:https": "pnpm data:sync && pnpm --filter @bookbat/webapp dev:https",
    "dev:astro": "pnpm data:sync && pnpm --filter @bookbat/astro-site dev",
    "build": "pnpm build:webapp",
    "build:webapp": "pnpm data:sync && pnpm --filter @bookbat/webapp build",
    "build:astro": "pnpm data:sync && pnpm --filter @bookbat/astro-site build",
    "test": "pnpm --filter @bookbat/webapp test",
    "lint": "pnpm -r lint",
    "format": "pnpm --filter @bookbat/webapp format",
    "preflight": "pnpm --filter @bookbat/webapp preflight"
  }
}
