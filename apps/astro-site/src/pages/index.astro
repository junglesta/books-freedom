---
import { parseLibraryPayload } from '@bookbat/library-core';
import BookBatClient from '../components/Astro/BookBatClient.astro';
import library from '../data/library.json';

const books = parseLibraryPayload(library);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>BOOK BAT | Library</title>
  </head>
  <body>
    <BookBatClient books={books} />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw-covers.js').catch(() => undefined);
      }
    </script>
  </body>
</html>
