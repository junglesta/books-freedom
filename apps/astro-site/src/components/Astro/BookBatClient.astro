---
import type { LibraryBook } from "@bookbat/library-core";
import {
    resolveBookBatClientConfig,
    type BookBatClientConfigOverride,
} from "../../config/bookbat-client.config";

interface Props {
    books?: LibraryBook[];
    dataUrl?: string;
    heading?: string;
    config?: BookBatClientConfigOverride;
}

const {
    books = [],
    dataUrl = "",
    heading = "BAOBAB",
    config = {},
} = Astro.props;
const resolvedConfig = resolveBookBatClientConfig(config);
const encodedBooks = encodeURIComponent(JSON.stringify(books));
const encodedConfig = encodeURIComponent(JSON.stringify(resolvedConfig));
---

<div
    class="bfc"
    data-bfc
    data-books={encodedBooks}
    data-data-url={dataUrl}
    data-heading={heading}
    data-config={encodedConfig}
>
    <section class="bfc_body">
        <header
            class="bfc_header"
            data-bfc-header
            hidden={!resolvedConfig.showHeader}
        >
            <h1>{heading}</h1>
        </header>
        <hr />

        <div class="bfc_controls">
            <label class="bfc_control bfc_control--search">
                <span>Search</span>
                <input
                    type="search"
                    data-bfc-search
                    placeholder="title, author, isbn..."
                />
            </label>
            <label class="bfc_control">
                <span>Sort</span>
                <div class="bfc_sort_row">
                    <select data-bfc-sort>
                        <option value="title">Title</option>
                        <option value="author">Author</option>
                        <option value="publisher">Publisher</option>
                        <option value="year">Year</option>
                    </select>
                    <button
                        class="bfc_sort_direction"
                        type="button"
                        data-bfc-sort-direction
                        aria-label="Reverse sort order"
                        title="Reverse sort order">↑</button
                    >
                </div>
            </label>
        </div>

        <p class="bfc_count" data-bfc-count>0 titles</p>
        <div class="bfc_list" data-bfc-list></div>
        <p class="bfc_empty" data-bfc-empty hidden>
            No books match your filters.
        </p>
    </section>
    <section class="bfc_export_wrap">
        <div class="bfc_export_slot" data-bfc-export-slot></div>
    </section>

    <footer
        class="bfc_footer"
        data-bfc-footer
        hidden={!resolvedConfig.showFooter}
    >
        <span class="bfc_footer_intro">
            <strong class="bfc_footer_brand">BAOBAB</strong> is the static browse/share layer, an Astro
            component designed to hold/display/share any of those nice JSONs
            tossed out by BOOKBATs.
        </span>
        <span>
            <a
                class="bfc_link bfc_footer_brand"
                href="https://bat.junglestar.org"
                target="_blank"
                rel="noreferrer noopener">BOOK BAT</a
            >
            is the active app layer (scan, edit, organize, export).
        </span>
        <span>
            Drop JSON in <code>data/library.json</code> (workspace root) or pass
            <code>dataUrl</code>.
        </span>
        <span>
            Open source:
            <a
                class="bfc_link"
                href="https://github.com/junglesta/bookbat"
                target="_blank"
                rel="noreferrer noopener">github.com/junglesta/bookbat</a
            >
        </span>
        <span>
            Licensed under
            <a
                class="bfc_link"
                href="https://creativecommons.org/licenses/by-sa/4.0/deed.en"
                target="_blank"
                rel="noreferrer noopener">CC BY-SA 4.0</a
            >
        </span>
    </footer>
</div>

<script is:inline>
    const statusLabel = {
        "to-read": "To Read",
        reading: "Reading",
        read: "Read",
    };

    const sorters = {
        title: (a, b) => (a.title || "").localeCompare(b.title || ""),
        author: (a, b) =>
            (a.authors?.[0] || "").localeCompare(b.authors?.[0] || ""),
        publisher: (a, b) =>
            (a.publisher || "").localeCompare(b.publisher || ""),
        year: (a, b) => (a.publishYear || 0) - (b.publishYear || 0),
    };
    const FORMULA_PREFIX_RE = /^[\t\r\n ]*[=+\-@]/;
    const PREFETCH_LIMIT = 120;
    const prefetchedCoverUrls = new Set();
    const defaultClientConfig = {
        showHeader: true,
        showFooter: true,
        unstyled: false,
        features: {
            export: {
                enabled: true,
                options: {
                    json: true,
                    csv: true,
                    goodreads: true,
                    librarything: true,
                },
            },
            load: {
                enabled: false,
            },
        },
    };
    const exportFormats = {
        json: { label: "JSON", ext: "json", mimeType: "application/json" },
        csv: { label: "CSV", ext: "csv", mimeType: "text/csv" },
        goodreads: { label: "Goodreads", ext: "csv", mimeType: "text/csv" },
        librarything: {
            label: "LibraryThing",
            ext: "tsv",
            mimeType: "text/tab-separated-values",
        },
    };
    const exportOptionMeta = {
        json: {
            buttonLabel: "JSON",
            description: "Raw book data",
            help: [
                "Downloads your full library as a .json file.",
                "Best format for backup and re-import.",
                "Includes all metadata, notes, and tags.",
            ],
        },
        csv: {
            buttonLabel: "CSV",
            description: "Spreadsheet format",
            help: [
                "Compatible with Excel, Google Sheets, and Numbers.",
                "Includes detailed columns for library management.",
                "Authors and tags are exported in delimited form.",
            ],
        },
        goodreads: {
            buttonLabel: "Goodreads",
            description: "Goodreads CSV",
            help: [
                "Formatted for Goodreads import workflow.",
                "Status is mapped to Goodreads shelves.",
                "Dates and ISBN fields follow Goodreads expectations.",
            ],
        },
        librarything: {
            buttonLabel: "LibraryThing",
            description: "LibraryThing TSV",
            help: [
                "Exports a tab-separated .tsv file.",
                "Designed for LibraryThing import mapping.",
                "Includes title, author, ISBN, rating, tags, and review fields.",
            ],
        },
    };

    function safeParseClientConfig(raw) {
        try {
            const parsed = JSON.parse(raw || "{}");
            const rawFeatures = parsed?.features || {};
            const rawExport = rawFeatures.export || {};
            const rawOptions = rawExport.options || {};
            const rawLoad = rawFeatures.load || {};
            return {
                showHeader:
                    parsed?.showHeader ?? defaultClientConfig.showHeader,
                showFooter:
                    parsed?.showFooter ?? defaultClientConfig.showFooter,
                unstyled: parsed?.unstyled ?? defaultClientConfig.unstyled,
                features: {
                    export: {
                        enabled:
                            rawExport.enabled ??
                            defaultClientConfig.features.export.enabled,
                        options: {
                            json:
                                rawOptions.json ??
                                defaultClientConfig.features.export.options
                                    .json,
                            csv:
                                rawOptions.csv ??
                                defaultClientConfig.features.export.options.csv,
                            goodreads:
                                rawOptions.goodreads ??
                                defaultClientConfig.features.export.options
                                    .goodreads,
                            librarything:
                                rawOptions.librarything ??
                                defaultClientConfig.features.export.options
                                    .librarything,
                        },
                    },
                    load: {
                        enabled:
                            rawLoad.enabled ??
                            defaultClientConfig.features.load.enabled,
                    },
                },
            };
        } catch {
            return defaultClientConfig;
        }
    }

    function mergeClientConfig(baseConfig, patchConfig = {}) {
        return safeParseClientConfig(
            JSON.stringify({
                ...baseConfig,
                ...patchConfig,
                features: {
                    ...baseConfig.features,
                    ...patchConfig.features,
                    export: {
                        ...baseConfig.features.export,
                        ...patchConfig.features?.export,
                        options: {
                            ...baseConfig.features.export.options,
                            ...patchConfig.features?.export?.options,
                        },
                    },
                    load: {
                        ...baseConfig.features.load,
                        ...patchConfig.features?.load,
                    },
                },
            }),
        );
    }

    function safeParseBooks(raw) {
        try {
            const parsed = JSON.parse(raw);
            if (!Array.isArray(parsed)) return [];
            return parsed.filter(
                (book) =>
                    book &&
                    typeof book === "object" &&
                    typeof book.id === "string" &&
                    typeof book.title === "string" &&
                    typeof book.isbn13 === "string" &&
                    Array.isArray(book.authors),
            );
        } catch {
            return [];
        }
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function coverUrl(book) {
        if (book.coverUrl && book.coverUrl.startsWith("https://"))
            return book.coverUrl;
        return `https://covers.openlibrary.org/b/isbn/${encodeURIComponent(book.isbn13)}-M.jpg?default=false`;
    }

    function statusChip(book) {
        const status = book.status || "to-read";
        const rating = Number.isFinite(book.rating)
            ? " " + "★".repeat(Math.max(0, Number(book.rating)))
            : "";
        const year = book.publishYear ? ` ${book.publishYear}` : "";
        return `${statusLabel[status] || "To Read"}${rating}${year}`;
    }

    function matchesQuery(book, query) {
        if (!query) return true;
        const haystack = [
            book.title || "",
            (book.authors || []).join(" "),
            book.isbn13 || "",
            book.publisher || "",
            (book.tags || []).join(" "),
        ]
            .join(" ")
            .toLowerCase();
        return haystack.includes(query);
    }

    async function loadFromUrl(url) {
        try {
            const response = await fetch(url, {
                headers: { Accept: "application/json" },
            });
            if (!response.ok) return [];
            const payload = await response.json();
            if (Array.isArray(payload)) return payload;
            if (payload && Array.isArray(payload.books)) return payload.books;
            return [];
        } catch {
            return [];
        }
    }

    function sanitizeSpreadsheetValue(value) {
        const safe = String(value ?? "");
        if (FORMULA_PREFIX_RE.test(safe)) return `'${safe}`;
        return safe;
    }

    function escapeCsv(value) {
        const safe = String(value ?? "");
        if (safe.includes(",") || safe.includes('"') || safe.includes("\n")) {
            return `"${safe.replace(/"/g, '""')}"`;
        }
        return safe;
    }

    function formatGoodreadsDate(isoDate) {
        if (!isoDate) return "";
        const parsed = new Date(isoDate);
        if (Number.isNaN(parsed.getTime())) return "";
        const yyyy = parsed.getFullYear();
        const mm = String(parsed.getMonth() + 1).padStart(2, "0");
        const dd = String(parsed.getDate()).padStart(2, "0");
        return `${yyyy}/${mm}/${dd}`;
    }

    function generateCsv(booksToExport) {
        const headers = [
            "Title",
            "Authors",
            "ISBN-13",
            "ISBN-10",
            "Publisher",
            "Publish Date",
            "Year",
            "Pages",
            "Language",
            "Status",
            "Rating",
            "Date Added",
            "Date Read",
            "Tags",
            "Notes",
        ];

        const rows = booksToExport.map((book) => [
            escapeCsv(sanitizeSpreadsheetValue(book.title)),
            escapeCsv(
                sanitizeSpreadsheetValue((book.authors || []).join("; ")),
            ),
            book.isbn13 || "",
            book.isbn10 || "",
            escapeCsv(sanitizeSpreadsheetValue(book.publisher || "")),
            escapeCsv(sanitizeSpreadsheetValue(book.publishDate || "")),
            book.publishYear?.toString() || "",
            book.pageCount?.toString() || "",
            sanitizeSpreadsheetValue(book.language || ""),
            book.status || "to-read",
            book.rating?.toString() || "",
            book.dateAdded || "",
            book.dateRead || "",
            escapeCsv(sanitizeSpreadsheetValue((book.tags || []).join("; "))),
            escapeCsv(sanitizeSpreadsheetValue(book.notes || "")),
        ]);

        return [headers.join(","), ...rows.map((row) => row.join(","))].join(
            "\n",
        );
    }

    function generateGoodreadsCsv(booksToExport) {
        const headers = [
            "Title",
            "Author",
            "ISBN",
            "ISBN13",
            "My Rating",
            "Number of Pages",
            "Year Published",
            "Date Read",
            "Date Added",
            "Exclusive Shelf",
            "My Review",
        ];
        const shelfMap = {
            "to-read": "to-read",
            reading: "currently-reading",
            read: "read",
        };

        const rows = booksToExport.map((book) => [
            escapeCsv(sanitizeSpreadsheetValue(book.title)),
            escapeCsv(sanitizeSpreadsheetValue((book.authors || [])[0] || "")),
            `="${book.isbn10 || ""}"`,
            `="${book.isbn13 || ""}"`,
            book.rating?.toString() || "0",
            book.pageCount?.toString() || "",
            book.publishYear?.toString() || "",
            book.dateRead ? formatGoodreadsDate(book.dateRead) : "",
            formatGoodreadsDate(book.dateAdded),
            shelfMap[book.status || "to-read"] || "to-read",
            escapeCsv(sanitizeSpreadsheetValue(book.notes || "")),
        ]);

        return [headers.join(","), ...rows.map((row) => row.join(","))].join(
            "\n",
        );
    }

    function generateLibraryThingTsv(booksToExport) {
        const headers = [
            "Title",
            "Author (First, Last)",
            "Date",
            "ISBN",
            "Rating",
            "Tags",
            "Review",
            "Page Count",
            "Publication",
            "Date Read",
        ];

        const rows = booksToExport.map((book) => [
            sanitizeSpreadsheetValue(book.title),
            sanitizeSpreadsheetValue((book.authors || [])[0] || ""),
            book.dateAdded ? String(book.dateAdded).split("T")[0] : "",
            book.isbn13 || "",
            book.rating?.toString() || "",
            sanitizeSpreadsheetValue((book.tags || []).join(", ")),
            sanitizeSpreadsheetValue(book.notes || ""),
            book.pageCount?.toString() || "",
            sanitizeSpreadsheetValue(book.publisher || ""),
            book.dateRead ? String(book.dateRead).split("T")[0] : "",
        ]);

        return [headers.join("\t"), ...rows.map((row) => row.join("\t"))].join(
            "\n",
        );
    }

    function toFilenameBase(value) {
        const normalized = String(value || "")
            .trim()
            .toLowerCase()
            .replace(/\s+/g, "-");
        const safe = normalized
            .replace(/[^a-z0-9._-]/g, "-")
            .replace(/-+/g, "-")
            .replace(/^-|-$/g, "");
        return safe || "library";
    }

    function getDatePrefix(date = new Date()) {
        const yy = String(date.getFullYear()).slice(-2);
        const mm = String(date.getMonth() + 1).padStart(2, "0");
        const dd = String(date.getDate()).padStart(2, "0");
        return `${yy}${mm}${dd}`;
    }

    function buildExportFilename(baseName, ext, totalBooks) {
        return `${getDatePrefix()}-${toFilenameBase(baseName)}-${totalBooks}.${ext}`;
    }

    function downloadBlob(content, filename, mimeType) {
        const blob = new Blob([content], { type: mimeType });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = filename;
        link.click();
        URL.revokeObjectURL(url);
    }

    function buildExportContent(formatId, booksToExport) {
        switch (formatId) {
            case "json":
                return JSON.stringify(
                    { version: 1, books: booksToExport },
                    null,
                    2,
                );
            case "csv":
                return generateCsv(booksToExport);
            case "goodreads":
                return generateGoodreadsCsv(booksToExport);
            case "librarything":
                return generateLibraryThingTsv(booksToExport);
            default:
                return "";
        }
    }

    function renderExportOption(formatId, optionMeta) {
        const helpItems = optionMeta.help
            .map((line) => `<li>${escapeHtml(line)}</li>`)
            .join("");
        const label = escapeHtml(optionMeta.buttonLabel);
        const description = escapeHtml(optionMeta.description);
        const ariaLabel = escapeHtml(
            `Help for ${optionMeta.buttonLabel} export`,
        );

        return `
          <div class="bfc_export_item">
            <div class="bfc_export_row">
              <button type="button" class="bfc_export_btn" data-bfc-export-format="${formatId}">
                <span class="bfc_export_btn_label">${label}</span>
                <span class="bfc_export_desc">${description}</span>
              </button>
              <button type="button" class="bfc_help_btn" data-bfc-export-help-toggle="${formatId}" aria-label="${ariaLabel}" aria-expanded="false">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                  <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
              </button>
            </div>
            <div class="bfc_help_panel" data-bfc-export-help="${formatId}" hidden>
              <ul>${helpItems}</ul>
            </div>
          </div>
        `;
    }

    function renderExportCard(exportOptions) {
        const enabledOptions = Object.entries(exportOptions)
            .filter(([, enabled]) => Boolean(enabled))
            .map(([formatId]) => formatId)
            .filter((formatId) => exportOptionMeta[formatId]);
        if (!enabledOptions.length) return "";
        const exportItems = enabledOptions
            .map((formatId) =>
                renderExportOption(formatId, exportOptionMeta[formatId]),
            )
            .join("");

        return `
          <article class="bfc_item bfc_item--export bfc_export" data-bfc-export>
            <div class="bfc_export_panel">
              <p class="bfc_export_heading">Export format:</p>
              ${exportItems}
              <p class="bfc_export_status" data-bfc-export-status aria-live="polite"></p>
            </div>
          </article>
        `;
    }

    function prewarmCoverCache(nextBooks) {
        if (typeof window === "undefined") return;

        const schedule = window.requestIdleCallback
            ? (fn) => window.requestIdleCallback(fn, { timeout: 1200 })
            : (fn) => window.setTimeout(fn, 16);

        schedule(() => {
            nextBooks
                .map((book) => coverUrl(book))
                .slice(0, PREFETCH_LIMIT)
                .forEach((url) => {
                    if (!url || prefetchedCoverUrls.has(url)) return;
                    prefetchedCoverUrls.add(url);

                    // Warm both browser cache and service worker cover cache.
                    const img = new Image();
                    img.decoding = "async";
                    img.referrerPolicy = "no-referrer";
                    img.src = url;
                });
        });
    }

    function mount(root) {
        const searchInput = root.querySelector("[data-bfc-search]");
        const sortInput = root.querySelector("[data-bfc-sort]");
        const sortDirectionInput = root.querySelector(
            "[data-bfc-sort-direction]",
        );
        const countNode = root.querySelector("[data-bfc-count]");
        const listNode = root.querySelector("[data-bfc-list]");
        const emptyNode = root.querySelector("[data-bfc-empty]");
        const exportWrapNode = root.querySelector(".bfc_export_wrap");
        const exportSlotNode = root.querySelector("[data-bfc-export-slot]");
        const headerNode = root.querySelector("[data-bfc-header]");
        const footerNode = root.querySelector("[data-bfc-footer]");
        const libraryName = root.dataset.heading || "library";
        let viewConfig = safeParseClientConfig(
            decodeURIComponent(root.dataset.config || "{}"),
        );

        let books = safeParseBooks(
            decodeURIComponent(root.dataset.books || "[]"),
        );
        let query = "";
        let sort = "title";
        let sortDirection = "asc";

        function syncSortDirectionControl() {
            if (!sortDirectionInput) return;
            sortDirectionInput.textContent = sortDirection === "asc" ? "↑" : "↓";
        }

        function applyViewConfig() {
            if (headerNode) {
                const hideHeader = !viewConfig.showHeader;
                headerNode.hidden = hideHeader;
                headerNode.classList.toggle("bfc_is_hidden", hideHeader);
            }
            if (footerNode) {
                const hideFooter = !viewConfig.showFooter;
                footerNode.hidden = hideFooter;
                footerNode.classList.toggle("bfc_is_hidden", hideFooter);
            }

            const styleNode = document.querySelector("[data-bfc-style]");
            if (styleNode instanceof HTMLStyleElement) {
                styleNode.media = viewConfig.unstyled ? "not all" : "all";
            }
        }

        async function hydrateFromUrlIfNeeded() {
            const url = (root.dataset.dataUrl || "").trim();
            if (books.length > 0 || !url) return;
            books = await loadFromUrl(url);
            prewarmCoverCache(books);
            render();
        }

        function render() {
            const sorter = sorters[sort] || sorters.title;
            const direction = sortDirection === "asc" ? 1 : -1;
            const filtered = books
                .filter((book) => matchesQuery(book, query))
                .sort((a, b) => sorter(a, b) * direction);

            countNode.textContent = `${filtered.length} title${filtered.length === 1 ? "" : "s"}`;
            emptyNode.hidden = filtered.length > 0;
            const cardsHtml = filtered
                .map((book) => {
                    const title = escapeHtml(book.title || "");
                    const authors = escapeHtml((book.authors || []).join(", "));
                    const publisher = book.publisher
                        ? escapeHtml(book.publisher)
                        : "";
                    const year = book.publishYear
                        ? escapeHtml(book.publishYear)
                        : "";
                    const pages = book.pageCount
                        ? `${escapeHtml(book.pageCount)} pages`
                        : "";
                    const notes = book.notes ? escapeHtml(book.notes) : "";
                    const tags = Array.isArray(book.tags)
                        ? book.tags.map((tag) => escapeHtml(tag)).join(", ")
                        : "";
                    const language = book.language
                        ? escapeHtml(book.language)
                        : "";
                    const isbn13 = escapeHtml(book.isbn13 || "");
                    const cover = escapeHtml(coverUrl(book));
                    const chip = escapeHtml(statusChip(book));

                    return `
            <details class="bfc_item">
              <summary class="bfc_summary">
                <div class="bfc_cover_wrap">
                  <div class="bfc_cover_placeholder" data-bfc-cover-placeholder aria-hidden="true">
                    <svg
                      class="bfc_cover_placeholder_icon"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    </svg>
                  </div>
                  <img class="bfc_cover_img" data-bfc-cover src="${cover}" alt="${title}" loading="lazy" referrerpolicy="no-referrer" />
                </div>
                <div class="bfc_main">
                  <span class="bfc_title">${title}</span>
                  <div class="bfc_meta">
                    <span class="bfc_authors">${authors}</span>
                    <span class="bfc_chip">${chip}</span>
                  </div>
                </div>
              </summary>
              <div class="bfc_detail">
                ${publisher ? `<p><strong>Publisher:</strong> ${publisher}</p>` : ""}
                ${year ? `<p><strong>Year:</strong> ${year}</p>` : ""}
                ${pages ? `<p><strong>Pages:</strong> ${pages}</p>` : ""}
                ${language ? `<p><strong>Language:</strong> ${language}</p>` : ""}
                ${notes ? `<p><strong>Notes:</strong> ${notes}</p>` : ""}
                ${tags ? `<p><strong>Tags:</strong> ${tags}</p>` : ""}
                <p><strong>ISBN-13:</strong> ${isbn13}</p>
              </div>
            </details>
          `;
                })
                .join("");
            const exportCardHtml = viewConfig.features.export.enabled
                ? renderExportCard(viewConfig.features.export.options)
                : "";
            listNode.innerHTML = cardsHtml;
            if (exportSlotNode) exportSlotNode.innerHTML = exportCardHtml;
            if (exportWrapNode)
                exportWrapNode.hidden = !Boolean(exportCardHtml);

            listNode.querySelectorAll("[data-bfc-cover]").forEach((img) => {
                const coverWrap = img.closest(".bfc_cover_wrap");
                if (!coverWrap) return;
                const coverPlaceholder = coverWrap.querySelector(
                    "[data-bfc-cover-placeholder]",
                );

                const markLoaded = () => {
                    coverWrap.classList.add("bfc_cover_loaded");
                    coverWrap.classList.remove("bfc_cover_failed");
                    img.classList.add("bfc_cover_img_loaded");
                    coverPlaceholder?.classList.add(
                        "bfc_cover_placeholder_hidden",
                    );
                };

                const markFailed = () => {
                    coverWrap.classList.add("bfc_cover_failed");
                    img.classList.remove("bfc_cover_img_loaded");
                    coverPlaceholder?.classList.remove(
                        "bfc_cover_placeholder_hidden",
                    );
                };

                if (img.complete) {
                    if (img.naturalWidth > 0) {
                        markLoaded();
                    } else {
                        markFailed();
                    }
                    return;
                }

                img.addEventListener("load", markLoaded, { once: true });
                img.addEventListener("error", markFailed, { once: true });
            });

            bindExportInteractions();
        }

        searchInput.addEventListener("input", (event) => {
            query = event.target.value.trim().toLowerCase();
            render();
        });

        syncSortDirectionControl();

        sortInput.addEventListener("change", (event) => {
            sort = event.target.value;
            render();
        });

        sortDirectionInput?.addEventListener("click", () => {
            sortDirection = sortDirection === "asc" ? "desc" : "asc";
            syncSortDirectionControl();
            render();
        });

        root.addEventListener("bfc:config", (event) => {
            const patch =
                event?.detail && typeof event.detail === "object"
                    ? event.detail
                    : {};
            viewConfig = mergeClientConfig(viewConfig, patch);
            applyViewConfig();
            render();
        });

        function bindExportInteractions() {
            const exportRoot = root.querySelector("[data-bfc-export]");
            if (!exportRoot) return;

            const exportButtons = exportRoot.querySelectorAll(
                "[data-bfc-export-format]",
            );
            const exportHelpToggles = exportRoot.querySelectorAll(
                "[data-bfc-export-help-toggle]",
            );
            const exportHelpPanels = exportRoot.querySelectorAll(
                "[data-bfc-export-help]",
            );
            const exportStatusNode = exportRoot.querySelector(
                "[data-bfc-export-status]",
            );

            exportButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const formatId = button.dataset.bfcExportFormat || "";
                    const format = exportFormats[formatId];
                    if (!format) return;

                    if (!books.length) {
                        if (exportStatusNode)
                            exportStatusNode.textContent =
                                "No books to export.";
                        return;
                    }

                    const content = buildExportContent(formatId, books);
                    if (!content) return;

                    const filename = buildExportFilename(
                        libraryName,
                        format.ext,
                        books.length,
                    );
                    downloadBlob(content, filename, format.mimeType);

                    if (exportStatusNode) {
                        exportStatusNode.textContent = `Exported ${format.label} (${books.length} books).`;
                    }
                });
            });

            function closeAllExportHelp(exceptId = "") {
                exportHelpPanels.forEach((panel) => {
                    const panelId = panel.dataset.bfcExportHelp || "";
                    const shouldHide = !exceptId || panelId !== exceptId;
                    if (shouldHide) panel.hidden = true;
                });

                exportHelpToggles.forEach((toggle) => {
                    const toggleId = toggle.dataset.bfcExportHelpToggle || "";
                    const isOpen = exceptId && toggleId === exceptId;
                    toggle.setAttribute(
                        "aria-expanded",
                        isOpen ? "true" : "false",
                    );
                });
            }

            exportHelpToggles.forEach((toggle) => {
                toggle.addEventListener("click", () => {
                    const targetId = toggle.dataset.bfcExportHelpToggle || "";
                    if (!targetId) return;

                    const targetPanel = exportRoot.querySelector(
                        `[data-bfc-export-help="${targetId}"]`,
                    );
                    if (!targetPanel) return;

                    const isOpening = targetPanel.hidden;
                    closeAllExportHelp(isOpening ? targetId : "");
                    targetPanel.hidden = !isOpening;
                });
            });
        }

        applyViewConfig();
        prewarmCoverCache(books);
        render();
        hydrateFromUrlIfNeeded();
    }

    document.querySelectorAll("[data-bfc]").forEach((root) => mount(root));
</script>

