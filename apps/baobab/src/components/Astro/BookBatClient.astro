---
import type { LibraryBook } from "@bookbat/library-core";
import {
    resolveBookBatClientConfig,
    type BookBatClientConfigOverride,
} from "../../config/bookbat-client.config";
import { version as baobabVersion } from "../../../package.json";
import { version as bookbatVersion } from "../../../../bookbat/package.json";

interface Props {
    books?: LibraryBook[];
    dataUrl?: string;
    heading?: string;
    config?: BookBatClientConfigOverride;
}

const {
    books = [],
    dataUrl = "",
    heading = "BAOBAB",
    config = {},
} = Astro.props;
const resolvedConfig = resolveBookBatClientConfig(config);
const encodedBooks = encodeURIComponent(JSON.stringify(books));
const encodedConfig = encodeURIComponent(JSON.stringify(resolvedConfig));
---

<div
    class="bfc"
    data-bfc
    data-books={encodedBooks}
    data-data-url={dataUrl}
    data-heading={heading}
    data-config={encodedConfig}
>
    <section class="bfc_body">
        <aside class="bfc_sidebar">
        <header
            class="bfc_header"
            data-bfc-header
            hidden={!resolvedConfig.showHeader}
        >
            <h1>{heading}</h1>
        </header>
        <hr />

        <div class="bfc_controls">
            <label class="bfc_control bfc_control--search">
                <span>Search</span>
                <input
                    type="search"
                    data-bfc-search
                    placeholder="title, author, isbn..."
                />
            </label>
            <label class="bfc_control">
                <span>Sort</span>
                <div class="bfc_sort_row">
                    <select data-bfc-sort>
                        <option value="recent">Recent</option>
                        <option value="title" selected>Title</option>
                        <option value="author">Author</option>
                        <option value="publisher">Publisher</option>
                        <option value="year">Year</option>
                        <option value="rating">Rating</option>
                    </select>
                    <button
                        class="bfc_sort_direction"
                        type="button"
                        data-bfc-sort-direction
                        aria-label="Reverse sort order"
                        title="Reverse sort order">↑</button
                    >
                </div>
            </label>
        </div>

        <div class="bfc_filter_row">
            <div
                class="bfc_status_tabs"
                role="tablist"
                data-bfc-status-tabs
            ></div>
            <label class="bfc_lang_filter">
                <span class="bfc_lang_filter_label">Language</span>
                <select data-bfc-language>
                    <option value="all">All</option>
                </select>
            </label>
            <div
                class="bfc_view_switch"
                role="group"
                aria-label="View mode"
            >
                <button
                    type="button"
                    class="bfc_view_seg"
                    data-bfc-view="card"
                    aria-label="Card view"
                    title="Card view"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        width="16"
                        height="16"
                        aria-hidden="true"
                    >
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                    </svg>
                </button>
                <button
                    type="button"
                    class="bfc_view_seg"
                    data-bfc-view="list"
                    aria-label="List view"
                    title="List view"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        width="16"
                        height="16"
                        aria-hidden="true"
                    >
                        <line x1="4" y1="6" x2="20" y2="6"></line>
                        <line x1="4" y1="12" x2="20" y2="12"></line>
                        <line x1="4" y1="18" x2="20" y2="18"></line>
                    </svg>
                </button>
            </div>
            <button
                type="button"
                class="bfc_expand_toggle"
                data-bfc-expand-toggle
                aria-label="Expand all cards"
                title="Expand all cards"
            >
                <span
                    class="bfc_expand_toggle_label"
                    data-bfc-expand-label
                    >Expand all</span
                >
                <svg
                    class="bfc_expand_toggle_icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    width="16"
                    height="16"
                    aria-hidden="true"
                >
                    <rect x="3" y="4" width="18" height="4" rx="1"></rect>
                    <rect x="3" y="11" width="18" height="4" rx="1"></rect>
                    <rect x="3" y="18" width="18" height="4" rx="1"></rect>
                </svg>
            </button>
        </div>

        </aside>
        <div class="bfc_main">
            <p class="bfc_count" data-bfc-count hidden>0 titles</p>
            <div class="bfc_list" data-bfc-list></div>
            <p class="bfc_empty" data-bfc-empty hidden>
                No books match your filters.
            </p>
        </div>
    </section>
    <section class="bfc_export_wrap">
        <div class="bfc_export_slot" data-bfc-export-slot></div>
    </section>

    <footer
        class="bfc_footer"
        data-bfc-footer
        hidden={!resolvedConfig.showFooter}
    >
        <span class="bfc_footer_brand_row">
            <a
                class="bfc_link bfc_footer_brand"
                href="https://baobab.junglestar.org/"
                target="_blank"
                rel="noreferrer noopener">BAOBAB</a
            >
            <span class="bfc_footer_brand_version">v{baobabVersion}</span>
        </span>
        <span class="bfc_footer_intro"> BAOBAB is the Astro component. </span>
        <span class="bfc_footer_intro">
            It's designed to work as a static block to display booklists.
        </span>
        <span>
            Drop JSON in <code>data/library.json</code> (workspace root) or pass
            <code>dataUrl</code>.
        </span>
        <span class="bfc_footer_brand_row">
            <a
                class="bfc_link bfc_footer_brand"
                href="https://bat.junglestar.org"
                target="_blank"
                rel="noreferrer noopener">BOOK BAT</a
            >
            <span class="bfc_footer_brand_version">v{bookbatVersion}</span>
        </span>
        <span class="bfc_footer_intro"> BOOKBAT is the webapp. </span>
        <span class="bfc_footer_intro">
            Scan. Edit. Sort. Merge. Import. Export.
        </span>
        <hr class="bfc_footer_divider" />
        <span>
            Both Webapp and Astro component by
            <a
                class="bfc_link"
                href="https://junglestar.org"
                target="_blank"
                rel="noreferrer noopener">junglestar.org</a
            >.
        </span>
        <span>
            Open source:
            <a
                class="bfc_link"
                href="https://github.com/junglesta/bookbat"
                target="_blank"
                rel="noreferrer noopener">github.com/junglesta/bookbat</a
            >
        </span>
        <span>
            Licensed under
            <a
                class="bfc_link"
                href="https://opensource.org/licenses/MIT"
                target="_blank"
                rel="noreferrer noopener">MIT</a
            >
        </span>
    </footer>
</div>

<script is:inline>
    const statusLabel = {
        "to-read": "To Read",
        reading: "Reading",
        read: "Read",
    };

    const sorters = {
        title: (a, b) => (a.title || "").localeCompare(b.title || ""),
        author: (a, b) =>
            (a.authors?.[0] || "").localeCompare(b.authors?.[0] || ""),
        publisher: (a, b) =>
            (a.publisher || "").localeCompare(b.publisher || ""),
        year: (a, b) => (a.publishYear || 0) - (b.publishYear || 0),
        recent: (a, b) => {
            const ta = a.dateAdded ? Date.parse(a.dateAdded) || 0 : 0;
            const tb = b.dateAdded ? Date.parse(b.dateAdded) || 0 : 0;
            return ta - tb;
        },
        rating: (a, b) => (Number(a.rating) || 0) - (Number(b.rating) || 0),
    };

    const statusFilterOptions = [
        { value: "all", label: "All" },
        { value: "to-read", label: "To Read" },
        { value: "reading", label: "Reading" },
        { value: "read", label: "Read" },
    ];
    const FORMULA_PREFIX_RE = /^[\t\r\n ]*[=+\-@]/;
    const PREFETCH_LIMIT = 500;
    const prefetchedCoverUrls = new Set();
    const defaultClientConfig = {
        showHeader: true,
        showFooter: true,
        unstyled: false,
        features: {
            export: {
                enabled: true,
                options: {
                    json: true,
                    csv: true,
                    goodreads: true,
                    librarything: true,
                },
            },
            load: {
                enabled: false,
            },
        },
    };
    const exportFormats = {
        json: { label: "JSON", ext: "json", mimeType: "application/json" },
        csv: { label: "CSV", ext: "csv", mimeType: "text/csv" },
        goodreads: { label: "Goodreads", ext: "csv", mimeType: "text/csv" },
        librarything: {
            label: "LibraryThing",
            ext: "tsv",
            mimeType: "text/tab-separated-values",
        },
    };
    const exportOptionMeta = {
        json: {
            buttonLabel: "JSON",
            description: "Raw book data",
            help: [
                "Downloads your full library as a .json file.",
                "Best format for backup and re-import.",
                "Includes all metadata, notes, and tags.",
            ],
        },
        csv: {
            buttonLabel: "CSV",
            description: "Spreadsheet format",
            help: [
                "Compatible with Excel, Google Sheets, and Numbers.",
                "Includes detailed columns for library management.",
                "Authors and tags are exported in delimited form.",
            ],
        },
        goodreads: {
            buttonLabel: "Goodreads",
            description: "Goodreads CSV",
            help: [
                "Formatted for Goodreads import workflow.",
                "Status is mapped to Goodreads shelves.",
                "Dates and ISBN fields follow Goodreads expectations.",
            ],
        },
        librarything: {
            buttonLabel: "LibraryThing",
            description: "LibraryThing TSV",
            help: [
                "Exports a tab-separated .tsv file.",
                "Designed for LibraryThing import mapping.",
                "Includes title, author, ISBN, rating, tags, and review fields.",
            ],
        },
    };

    function safeParseClientConfig(raw) {
        try {
            const parsed = JSON.parse(raw || "{}");
            const rawFeatures = parsed?.features || {};
            const rawExport = rawFeatures.export || {};
            const rawOptions = rawExport.options || {};
            const rawLoad = rawFeatures.load || {};
            return {
                showHeader:
                    parsed?.showHeader ?? defaultClientConfig.showHeader,
                showFooter:
                    parsed?.showFooter ?? defaultClientConfig.showFooter,
                unstyled: parsed?.unstyled ?? defaultClientConfig.unstyled,
                features: {
                    export: {
                        enabled:
                            rawExport.enabled ??
                            defaultClientConfig.features.export.enabled,
                        options: {
                            json:
                                rawOptions.json ??
                                defaultClientConfig.features.export.options
                                    .json,
                            csv:
                                rawOptions.csv ??
                                defaultClientConfig.features.export.options.csv,
                            goodreads:
                                rawOptions.goodreads ??
                                defaultClientConfig.features.export.options
                                    .goodreads,
                            librarything:
                                rawOptions.librarything ??
                                defaultClientConfig.features.export.options
                                    .librarything,
                        },
                    },
                    load: {
                        enabled:
                            rawLoad.enabled ??
                            defaultClientConfig.features.load.enabled,
                    },
                },
            };
        } catch {
            return defaultClientConfig;
        }
    }

    function mergeClientConfig(baseConfig, patchConfig = {}) {
        return safeParseClientConfig(
            JSON.stringify({
                ...baseConfig,
                ...patchConfig,
                features: {
                    ...baseConfig.features,
                    ...patchConfig.features,
                    export: {
                        ...baseConfig.features.export,
                        ...patchConfig.features?.export,
                        options: {
                            ...baseConfig.features.export.options,
                            ...patchConfig.features?.export?.options,
                        },
                    },
                    load: {
                        ...baseConfig.features.load,
                        ...patchConfig.features?.load,
                    },
                },
            }),
        );
    }

    function safeParseBooks(raw) {
        try {
            const parsed = JSON.parse(raw);
            if (!Array.isArray(parsed)) return [];
            return parsed.filter(
                (book) =>
                    book &&
                    typeof book === "object" &&
                    typeof book.id === "string" &&
                    typeof book.title === "string" &&
                    typeof book.isbn13 === "string" &&
                    Array.isArray(book.authors),
            );
        } catch {
            return [];
        }
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function coverUrl(book) {
        if (book.coverUrl && book.coverUrl.startsWith("https://"))
            return book.coverUrl;
        // No `?default=false`: openlibrary then always returns 200, with a tiny
        // transparent placeholder when the cover is missing. We detect that case
        // via naturalWidth in the load handler. Avoiding 404 keeps the service
        // worker from caching poisoned opaque responses across sessions.
        return `https://covers.openlibrary.org/b/isbn/${encodeURIComponent(book.isbn13)}-M.jpg`;
    }

    // A real cover from openlibrary is at least ~50px wide; smaller means the
    // server returned a 1×1 transparent placeholder.
    const COVER_MIN_WIDTH = 10;

    function statusChip(book) {
        const status = book.status || "to-read";
        const stars = Number.isFinite(book.rating)
            ? " " + "★".repeat(Math.max(0, Number(book.rating)))
            : "";
        const year = book.publishYear ? `${book.publishYear} ` : "";
        return `${year}${statusLabel[status] || "To Read"}${stars}`;
    }

    function generateBookText(book, { includeTitle = true } = {}) {
        return [
            includeTitle ? book.title : "",
            (book.authors || []).join(", "),
            book.publisher,
            book.publishYear ? String(book.publishYear) : "",
            book.pageCount ? `${book.pageCount} pages` : "",
            book.isbn13 ? `ISBN: ${book.isbn13}` : "",
            (book.synopsis || "").trim(),
        ]
            .filter((line) => typeof line === "string" && line.trim().length > 0)
            .join("\n");
    }

    function matchesQuery(book, query) {
        if (!query) return true;
        const haystack = [
            book.title || "",
            (book.authors || []).join(" "),
            book.isbn13 || "",
            book.publisher || "",
            (book.tags || []).join(" "),
        ]
            .join(" ")
            .toLowerCase();
        return haystack.includes(query);
    }

    async function loadFromUrl(url) {
        try {
            const response = await fetch(url, {
                headers: { Accept: "application/json" },
            });
            if (!response.ok) return [];
            const payload = await response.json();
            if (Array.isArray(payload)) return payload;
            if (payload && Array.isArray(payload.books)) return payload.books;
            return [];
        } catch {
            return [];
        }
    }

    function sanitizeSpreadsheetValue(value) {
        const safe = String(value ?? "");
        if (FORMULA_PREFIX_RE.test(safe)) return `'${safe}`;
        return safe;
    }

    function escapeCsv(value) {
        const safe = String(value ?? "");
        if (safe.includes(",") || safe.includes('"') || safe.includes("\n")) {
            return `"${safe.replace(/"/g, '""')}"`;
        }
        return safe;
    }

    function formatGoodreadsDate(isoDate) {
        if (!isoDate) return "";
        const parsed = new Date(isoDate);
        if (Number.isNaN(parsed.getTime())) return "";
        const yyyy = parsed.getFullYear();
        const mm = String(parsed.getMonth() + 1).padStart(2, "0");
        const dd = String(parsed.getDate()).padStart(2, "0");
        return `${yyyy}/${mm}/${dd}`;
    }

    function generateCsv(booksToExport) {
        const headers = [
            "Title",
            "Authors",
            "ISBN-13",
            "ISBN-10",
            "Publisher",
            "Publish Date",
            "Year",
            "Pages",
            "Language",
            "Status",
            "Rating",
            "Date Added",
            "Date Read",
            "Tags",
            "Notes",
        ];

        const rows = booksToExport.map((book) => [
            escapeCsv(sanitizeSpreadsheetValue(book.title)),
            escapeCsv(
                sanitizeSpreadsheetValue((book.authors || []).join("; ")),
            ),
            book.isbn13 || "",
            book.isbn10 || "",
            escapeCsv(sanitizeSpreadsheetValue(book.publisher || "")),
            escapeCsv(sanitizeSpreadsheetValue(book.publishDate || "")),
            book.publishYear?.toString() || "",
            book.pageCount?.toString() || "",
            sanitizeSpreadsheetValue(book.language || ""),
            book.status || "to-read",
            book.rating?.toString() || "",
            book.dateAdded || "",
            book.dateRead || "",
            escapeCsv(sanitizeSpreadsheetValue((book.tags || []).join("; "))),
            escapeCsv(sanitizeSpreadsheetValue(book.notes || "")),
        ]);

        return [headers.join(","), ...rows.map((row) => row.join(","))].join(
            "\n",
        );
    }

    function generateGoodreadsCsv(booksToExport) {
        const headers = [
            "Title",
            "Author",
            "ISBN",
            "ISBN13",
            "My Rating",
            "Number of Pages",
            "Year Published",
            "Date Read",
            "Date Added",
            "Exclusive Shelf",
            "My Review",
        ];
        const shelfMap = {
            "to-read": "to-read",
            reading: "currently-reading",
            read: "read",
        };

        const rows = booksToExport.map((book) => [
            escapeCsv(sanitizeSpreadsheetValue(book.title)),
            escapeCsv(sanitizeSpreadsheetValue((book.authors || [])[0] || "")),
            `="${book.isbn10 || ""}"`,
            `="${book.isbn13 || ""}"`,
            book.rating?.toString() || "0",
            book.pageCount?.toString() || "",
            book.publishYear?.toString() || "",
            book.dateRead ? formatGoodreadsDate(book.dateRead) : "",
            formatGoodreadsDate(book.dateAdded),
            shelfMap[book.status || "to-read"] || "to-read",
            escapeCsv(sanitizeSpreadsheetValue(book.notes || "")),
        ]);

        return [headers.join(","), ...rows.map((row) => row.join(","))].join(
            "\n",
        );
    }

    function generateLibraryThingTsv(booksToExport) {
        const headers = [
            "Title",
            "Author (First, Last)",
            "Date",
            "ISBN",
            "Rating",
            "Tags",
            "Review",
            "Page Count",
            "Publication",
            "Date Read",
        ];

        const rows = booksToExport.map((book) => [
            sanitizeSpreadsheetValue(book.title),
            sanitizeSpreadsheetValue((book.authors || [])[0] || ""),
            book.dateAdded ? String(book.dateAdded).split("T")[0] : "",
            book.isbn13 || "",
            book.rating?.toString() || "",
            sanitizeSpreadsheetValue((book.tags || []).join(", ")),
            sanitizeSpreadsheetValue(book.notes || ""),
            book.pageCount?.toString() || "",
            sanitizeSpreadsheetValue(book.publisher || ""),
            book.dateRead ? String(book.dateRead).split("T")[0] : "",
        ]);

        return [headers.join("\t"), ...rows.map((row) => row.join("\t"))].join(
            "\n",
        );
    }

    function toFilenameBase(value) {
        const normalized = String(value || "")
            .trim()
            .toLowerCase()
            .replace(/\s+/g, "-");
        const safe = normalized
            .replace(/[^a-z0-9._-]/g, "-")
            .replace(/-+/g, "-")
            .replace(/^-|-$/g, "");
        return safe || "library";
    }

    function getDatePrefix(date = new Date()) {
        const yy = String(date.getFullYear()).slice(-2);
        const mm = String(date.getMonth() + 1).padStart(2, "0");
        const dd = String(date.getDate()).padStart(2, "0");
        return `${yy}${mm}${dd}`;
    }

    function buildExportFilename(baseName, ext, totalBooks) {
        return `${getDatePrefix()}-${toFilenameBase(baseName)}-${totalBooks}.${ext}`;
    }

    function downloadBlob(content, filename, mimeType) {
        const blob = new Blob([content], { type: mimeType });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = filename;
        link.click();
        URL.revokeObjectURL(url);
    }

    function buildExportContent(formatId, booksToExport) {
        switch (formatId) {
            case "json":
                return JSON.stringify(
                    { version: 1, books: booksToExport },
                    null,
                    2,
                );
            case "csv":
                return generateCsv(booksToExport);
            case "goodreads":
                return generateGoodreadsCsv(booksToExport);
            case "librarything":
                return generateLibraryThingTsv(booksToExport);
            default:
                return "";
        }
    }

    function renderExportOption(formatId, optionMeta) {
        const helpItems = optionMeta.help
            .map((line) => `<li>${escapeHtml(line)}</li>`)
            .join("");
        const label = escapeHtml(optionMeta.buttonLabel);
        const description = escapeHtml(optionMeta.description);
        const ariaLabel = escapeHtml(
            `Help for ${optionMeta.buttonLabel} export`,
        );

        return `
          <div class="bfc_export_item">
            <div class="bfc_export_row">
              <button type="button" class="bfc_export_btn" data-bfc-export-format="${formatId}">
                <span class="bfc_export_btn_label">${label}</span>
                <span class="bfc_export_desc">${description}</span>
              </button>
              <button type="button" class="bfc_help_btn" data-bfc-export-help-toggle="${formatId}" aria-label="${ariaLabel}" aria-expanded="false">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                  <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
              </button>
            </div>
            <div class="bfc_help_panel" data-bfc-export-help="${formatId}" hidden>
              <ul>${helpItems}</ul>
            </div>
          </div>
        `;
    }

    function renderExportCard(exportOptions) {
        const enabledOptions = Object.entries(exportOptions)
            .filter(([, enabled]) => Boolean(enabled))
            .map(([formatId]) => formatId)
            .filter((formatId) => exportOptionMeta[formatId]);
        if (!enabledOptions.length) return "";
        const exportItems = enabledOptions
            .map((formatId) =>
                renderExportOption(formatId, exportOptionMeta[formatId]),
            )
            .join("");

        return `
          <article class="bfc_item bfc_item--export bfc_export" data-bfc-export>
            <div class="bfc_export_panel">
              <p class="bfc_export_heading">Export format:</p>
              ${exportItems}
              <p class="bfc_export_status" data-bfc-export-status aria-live="polite"></p>
            </div>
          </article>
        `;
    }

    function prewarmCoverCache(nextBooks) {
        if (typeof window === "undefined") return;

        const schedule = window.requestIdleCallback
            ? (fn) => window.requestIdleCallback(fn, { timeout: 1200 })
            : (fn) => window.setTimeout(fn, 16);

        schedule(() => {
            nextBooks
                .map((book) => coverUrl(book))
                .slice(0, PREFETCH_LIMIT)
                .forEach((url) => {
                    if (!url || prefetchedCoverUrls.has(url)) return;
                    prefetchedCoverUrls.add(url);

                    // Warm both browser cache and service worker cover cache.
                    const img = new Image();
                    img.decoding = "async";
                    img.referrerPolicy = "no-referrer";
                    img.src = url;
                });
        });
    }

    function mount(root) {
        const searchInput = root.querySelector("[data-bfc-search]");
        const sortInput = root.querySelector("[data-bfc-sort]");
        const sortDirectionInput = root.querySelector(
            "[data-bfc-sort-direction]",
        );
        const countNode = root.querySelector("[data-bfc-count]");
        const listNode = root.querySelector("[data-bfc-list]");
        const emptyNode = root.querySelector("[data-bfc-empty]");
        const statusTabsNode = root.querySelector("[data-bfc-status-tabs]");
        const languageInput = root.querySelector("[data-bfc-language]");
        const viewSwitchNode = root.querySelector(".bfc_view_switch");
        const viewSegButtons = root.querySelectorAll("[data-bfc-view]");
        const expandToggleBtn = root.querySelector("[data-bfc-expand-toggle]");
        const expandLabelNode = root.querySelector("[data-bfc-expand-label]");
        const exportWrapNode = root.querySelector(".bfc_export_wrap");
        const exportSlotNode = root.querySelector("[data-bfc-export-slot]");
        const headerNode = root.querySelector("[data-bfc-header]");
        const footerNode = root.querySelector("[data-bfc-footer]");
        const libraryName = root.dataset.heading || "library";
        let viewConfig = safeParseClientConfig(
            decodeURIComponent(root.dataset.config || "{}"),
        );

        let books = safeParseBooks(
            decodeURIComponent(root.dataset.books || "[]"),
        );
        let query = "";
        let sort = "title";
        let sortDirection = "asc";
        let statusFilter = "all";
        let languageFilter = "all";
        let viewMode = "list";

        function applyViewMode() {
            listNode.classList.toggle("bfc_list--compact", viewMode === "list");
            viewSegButtons.forEach((btn) => {
                const isActive = btn.dataset.bfcView === viewMode;
                btn.classList.toggle("bfc_view_seg--active", isActive);
                btn.setAttribute("aria-pressed", isActive ? "true" : "false");
            });
        }

        function bookLanguage(book) {
            return (book.language || "").trim();
        }

        function uniqueLanguages() {
            const set = new Set();
            for (const b of books) {
                set.add(bookLanguage(b));
            }
            return [...set].sort((a, b) => {
                if (a === "") return 1;
                if (b === "") return -1;
                return a.localeCompare(b);
            });
        }

        function syncLanguageOptions() {
            if (!languageInput) return;
            const langs = uniqueLanguages();
            const opts = ['<option value="all">All</option>'];
            for (const lang of langs) {
                const value = lang === "" ? "__none__" : lang;
                const label = lang === "" ? "(unspecified)" : lang;
                opts.push(
                    `<option value="${escapeHtml(value)}">${escapeHtml(label)}</option>`,
                );
            }
            languageInput.innerHTML = opts.join("");
            languageInput.value = languageFilter;
            if (languageInput.value !== languageFilter) {
                languageFilter = "all";
                languageInput.value = "all";
            }
        }

        function matchesLanguage(book) {
            if (languageFilter === "all") return true;
            const lang = bookLanguage(book);
            if (languageFilter === "__none__") return lang === "";
            return lang === languageFilter;
        }

        function bookStatus(book) {
            return book.status || "to-read";
        }

        function statusCount(value) {
            if (value === "all") return books.length;
            return books.filter((b) => bookStatus(b) === value).length;
        }

        function renderStatusTabs() {
            if (!statusTabsNode) return;
            statusTabsNode.innerHTML = statusFilterOptions
                .map((opt) => {
                    const isActive = statusFilter === opt.value;
                    return `<button type="button" class="bfc_status_tab${isActive ? " bfc_status_tab--active" : ""}" data-bfc-status-tab="${opt.value}" role="tab" aria-selected="${isActive}"><span class="bfc_status_tab_label">${escapeHtml(opt.label)}</span> <span class="bfc_status_tab_count">${statusCount(opt.value)}</span></button>`;
                })
                .join("");
        }

        function syncSortDirectionControl() {
            if (!sortDirectionInput) return;
            sortDirectionInput.textContent =
                sortDirection === "asc" ? "↑" : "↓";
        }

        function applyViewConfig() {
            if (headerNode) {
                const hideHeader = !viewConfig.showHeader;
                headerNode.hidden = hideHeader;
                headerNode.classList.toggle("bfc_is_hidden", hideHeader);
            }
            if (footerNode) {
                const hideFooter = !viewConfig.showFooter;
                footerNode.hidden = hideFooter;
                footerNode.classList.toggle("bfc_is_hidden", hideFooter);
            }

            const styleNode = document.querySelector("[data-bfc-style]");
            if (styleNode instanceof HTMLStyleElement) {
                styleNode.media = viewConfig.unstyled ? "not all" : "all";
            }
        }

        async function hydrateFromUrlIfNeeded() {
            const url = (root.dataset.dataUrl || "").trim();
            if (books.length > 0 || !url) return;
            books = await loadFromUrl(url);
            prewarmCoverCache(books);
            render();
        }

        function render() {
            renderStatusTabs();
            syncLanguageOptions();
            const sorter = sorters[sort] || sorters.title;
            const direction = sortDirection === "asc" ? 1 : -1;
            const filtered = books
                .filter(
                    (book) =>
                        statusFilter === "all" ||
                        bookStatus(book) === statusFilter,
                )
                .filter(matchesLanguage)
                .filter((book) => matchesQuery(book, query))
                .sort((a, b) => sorter(a, b) * direction);

            countNode.textContent = `${filtered.length} title${filtered.length === 1 ? "" : "s"}`;
            emptyNode.hidden = filtered.length > 0;
            const cardsHtml = filtered
                .map((book) => {
                    const title = escapeHtml(book.title || "");
                    const authors = escapeHtml((book.authors || []).join(", "));
                    const publisher = book.publisher
                        ? escapeHtml(book.publisher)
                        : "";
                    const year = book.publishYear
                        ? escapeHtml(book.publishYear)
                        : "";
                    const pages = book.pageCount
                        ? `${escapeHtml(book.pageCount)} pages`
                        : "";
                    const notes = book.notes ? escapeHtml(book.notes) : "";
                    const synopsis = book.synopsis
                        ? escapeHtml(book.synopsis)
                        : "";
                    const tags = Array.isArray(book.tags)
                        ? book.tags.map((tag) => escapeHtml(tag)).join(", ")
                        : "";
                    const language = book.language
                        ? escapeHtml(book.language)
                        : "";
                    const isbn13 = escapeHtml(book.isbn13 || "");
                    const cover = escapeHtml(coverUrl(book));
                    const chip = escapeHtml(statusChip(book));

                    const bookId = escapeHtml(book.id || "");
                    return `
            <details class="bfc_item" data-bfc-book-id="${bookId}">
              <summary class="bfc_summary">
                <div class="bfc_cover_wrap">
                  <div class="bfc_cover_placeholder" data-bfc-cover-placeholder aria-hidden="true">
                    <svg
                      class="bfc_cover_placeholder_icon"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    </svg>
                  </div>
                  <img class="bfc_cover_img" data-bfc-cover src="${cover}" alt="${title}" loading="lazy" referrerpolicy="no-referrer" />
                </div>
                <div class="bfc_main">
                  <span class="bfc_title">${title}</span>
                  <div class="bfc_meta">
                    <span class="bfc_authors">${authors}</span>
                    <span class="bfc_chip">${chip}</span>
                  </div>
                </div>
              </summary>
              <div class="bfc_detail">
                <div class="bfc_detail_cover" data-bfc-detail-cover>
                  <img
                    class="bfc_detail_cover_img"
                    data-bfc-detail-cover-img
                    src="${cover}"
                    alt="${title}"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                  />
                </div>
                <div class="bfc_detail_body">
                  <dl class="bfc_meta_grid">
                    ${publisher ? `<dt>Publisher</dt><dd>${publisher}</dd>` : ""}
                    ${year ? `<dt>Year</dt><dd>${year}</dd>` : ""}
                    ${pages ? `<dt>Pages</dt><dd>${pages}</dd>` : ""}
                    ${language ? `<dt>Language</dt><dd>${language}</dd>` : ""}
                    ${tags ? `<dt>Tags</dt><dd>${tags}</dd>` : ""}
                    ${notes ? `<dt>Notes</dt><dd>${notes}</dd>` : ""}
                    <dt>ISBN-13</dt><dd>${isbn13}</dd>
                  </dl>
                  ${synopsis ? `<div class="bfc_synopsis"><h4 class="bfc_synopsis_label">Synopsis</h4><p>${synopsis}</p></div>` : ""}
                  <div class="bfc_actions" data-bfc-actions>
                    <button type="button" class="bfc_action_btn" data-bfc-share="${bookId}" hidden>Share</button>
                    <a class="bfc_action_btn" data-bfc-email="${bookId}" href="#" role="button">Email</a>
                    <button type="button" class="bfc_action_btn" data-bfc-copy="${bookId}">
                      <span data-bfc-copy-label>Copy book info</span>
                    </button>
                  </div>
                </div>
              </div>
            </details>
          `;
                })
                .join("");
            const exportCardHtml = viewConfig.features.export.enabled
                ? renderExportCard(viewConfig.features.export.options)
                : "";
            listNode.innerHTML = cardsHtml;
            if (exportSlotNode) exportSlotNode.innerHTML = exportCardHtml;
            if (exportWrapNode)
                exportWrapNode.hidden = !Boolean(exportCardHtml);

            listNode.querySelectorAll("[data-bfc-cover]").forEach((img) => {
                const coverWrap = img.closest(".bfc_cover_wrap");
                if (!coverWrap) return;
                const coverPlaceholder = coverWrap.querySelector(
                    "[data-bfc-cover-placeholder]",
                );

                const markLoaded = () => {
                    coverWrap.classList.add("bfc_cover_loaded");
                    coverWrap.classList.remove("bfc_cover_failed");
                    img.classList.add("bfc_cover_img_loaded");
                    coverPlaceholder?.classList.add(
                        "bfc_cover_placeholder_hidden",
                    );
                };

                const markFailed = () => {
                    coverWrap.classList.add("bfc_cover_failed");
                    img.classList.remove("bfc_cover_img_loaded");
                    coverPlaceholder?.classList.remove(
                        "bfc_cover_placeholder_hidden",
                    );
                };

                const settle = () => {
                    if (img.naturalWidth >= COVER_MIN_WIDTH) markLoaded();
                    else markFailed();
                };

                if (img.complete) {
                    settle();
                    return;
                }

                img.addEventListener("load", settle, { once: true });
                img.addEventListener("error", markFailed, { once: true });
            });

            listNode
                .querySelectorAll("[data-bfc-detail-cover-img]")
                .forEach((img) => {
                    const wrap = img.closest("[data-bfc-detail-cover]");
                    if (!wrap) return;
                    const settle = () => {
                        if (img.naturalWidth >= COVER_MIN_WIDTH) {
                            wrap.classList.add("bfc_detail_cover--loaded");
                            wrap.classList.remove("bfc_detail_cover--failed");
                        } else {
                            wrap.classList.add("bfc_detail_cover--failed");
                            wrap.classList.remove("bfc_detail_cover--loaded");
                        }
                    };
                    if (img.complete) {
                        settle();
                        return;
                    }
                    img.addEventListener("load", settle, { once: true });
                    img.addEventListener(
                        "error",
                        () => {
                            wrap.classList.add("bfc_detail_cover--failed");
                        },
                        { once: true },
                    );
                });

            applyShareAvailability();
            bindExportInteractions();
            updateExpandToggleFromDom();
        }

        function applyShareAvailability() {
            const canShare =
                typeof navigator !== "undefined" &&
                typeof navigator.share === "function";
            if (!canShare) return;
            listNode
                .querySelectorAll("[data-bfc-share]")
                .forEach((btn) => {
                    btn.hidden = false;
                });
        }

        function findBookById(id) {
            return books.find((book) => book.id === id);
        }

        listNode.addEventListener("click", async (event) => {
            const target = event.target instanceof Element ? event.target : null;
            if (!target) return;
            const shareBtn = target.closest("[data-bfc-share]");
            const emailBtn = target.closest("[data-bfc-email]");
            const copyBtn = target.closest("[data-bfc-copy]");

            if (emailBtn) {
                event.preventDefault();
                const id = emailBtn.dataset.bfcEmail || "";
                const book = findBookById(id);
                if (!book) return;
                const subject = encodeURIComponent(book.title || "");
                const body = encodeURIComponent(
                    generateBookText(book, { includeTitle: false }),
                );
                window.location.href = `mailto:?subject=${subject}&body=${body}`;
                return;
            }

            if (shareBtn) {
                event.preventDefault();
                const id = shareBtn.dataset.bfcShare || "";
                const book = findBookById(id);
                if (!book || typeof navigator.share !== "function") return;
                if (shareBtn.disabled) return;
                shareBtn.disabled = true;
                try {
                    await navigator.share({
                        title: book.title,
                        text: generateBookText(book, { includeTitle: false }),
                    });
                } catch (err) {
                    if (!err || err.name !== "AbortError") {
                        console.warn("share failed", err);
                    }
                } finally {
                    shareBtn.disabled = false;
                }
                return;
            }

            if (copyBtn) {
                event.preventDefault();
                const id = copyBtn.dataset.bfcCopy || "";
                const book = findBookById(id);
                if (!book) return;
                const labelNode = copyBtn.querySelector("[data-bfc-copy-label]");
                try {
                    await navigator.clipboard.writeText(generateBookText(book));
                    if (labelNode) {
                        const prev = labelNode.textContent;
                        labelNode.textContent = "Copied!";
                        copyBtn.classList.add("bfc_action_btn--success");
                        setTimeout(() => {
                            labelNode.textContent = prev || "Copy book info";
                            copyBtn.classList.remove("bfc_action_btn--success");
                        }, 1200);
                    }
                } catch (err) {
                    console.warn("copy failed", err);
                    if (labelNode) labelNode.textContent = "Copy failed";
                }
            }
        });

        searchInput.addEventListener("input", (event) => {
            query = event.target.value.trim().toLowerCase();
            render();
        });

        syncSortDirectionControl();

        sortInput.addEventListener("change", (event) => {
            sort = event.target.value;
            render();
        });

        sortDirectionInput?.addEventListener("click", () => {
            sortDirection = sortDirection === "asc" ? "desc" : "asc";
            syncSortDirectionControl();
            render();
        });

        languageInput?.addEventListener("change", (event) => {
            languageFilter = event.target.value || "all";
            render();
        });

        function setExpandToggleState(allOpen) {
            if (!expandToggleBtn) return;
            const label = allOpen ? "Collapse all" : "Expand all";
            expandToggleBtn.setAttribute("aria-label", label);
            expandToggleBtn.setAttribute("title", label);
            if (expandLabelNode) expandLabelNode.textContent = label;
        }

        function updateExpandToggleFromDom() {
            const items = listNode.querySelectorAll("details.bfc_item");
            if (!items.length) {
                setExpandToggleState(false);
                return;
            }
            const allOpen = Array.from(items).every((d) => d.open);
            setExpandToggleState(allOpen);
        }

        expandToggleBtn?.addEventListener("click", () => {
            const items = listNode.querySelectorAll("details.bfc_item");
            if (!items.length) return;
            const allOpen = Array.from(items).every((d) => d.open);
            const shouldOpen = !allOpen;
            items.forEach((d) => {
                d.open = shouldOpen;
            });
            setExpandToggleState(shouldOpen);
        });

        listNode.addEventListener(
            "toggle",
            () => updateExpandToggleFromDom(),
            true,
        );

        viewSwitchNode?.addEventListener("click", (event) => {
            const target = event.target instanceof Element ? event.target : null;
            const btn = target?.closest("[data-bfc-view]");
            if (!btn) return;
            const next = btn.dataset.bfcView === "list" ? "list" : "card";
            if (next === viewMode) return;
            viewMode = next;
            applyViewMode();
        });
        applyViewMode();

        statusTabsNode?.addEventListener("click", (event) => {
            const target = event.target instanceof Element ? event.target : null;
            const btn = target?.closest("[data-bfc-status-tab]");
            if (!btn) return;
            const value = btn.dataset.bfcStatusTab || "all";
            if (value === statusFilter) return;
            statusFilter = value;
            render();
        });

        root.addEventListener("bfc:config", (event) => {
            const patch =
                event?.detail && typeof event.detail === "object"
                    ? event.detail
                    : {};
            viewConfig = mergeClientConfig(viewConfig, patch);
            applyViewConfig();
            render();
        });

        function bindExportInteractions() {
            const exportRoot = root.querySelector("[data-bfc-export]");
            if (!exportRoot) return;

            const exportButtons = exportRoot.querySelectorAll(
                "[data-bfc-export-format]",
            );
            const exportHelpToggles = exportRoot.querySelectorAll(
                "[data-bfc-export-help-toggle]",
            );
            const exportHelpPanels = exportRoot.querySelectorAll(
                "[data-bfc-export-help]",
            );
            const exportStatusNode = exportRoot.querySelector(
                "[data-bfc-export-status]",
            );

            exportButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const formatId = button.dataset.bfcExportFormat || "";
                    const format = exportFormats[formatId];
                    if (!format) return;

                    if (!books.length) {
                        if (exportStatusNode)
                            exportStatusNode.textContent =
                                "No books to export.";
                        return;
                    }

                    const content = buildExportContent(formatId, books);
                    if (!content) return;

                    const filename = buildExportFilename(
                        libraryName,
                        format.ext,
                        books.length,
                    );
                    downloadBlob(content, filename, format.mimeType);

                    if (exportStatusNode) {
                        exportStatusNode.textContent = `Exported ${format.label} (${books.length} books).`;
                    }
                });
            });

            function closeAllExportHelp(exceptId = "") {
                exportHelpPanels.forEach((panel) => {
                    const panelId = panel.dataset.bfcExportHelp || "";
                    const shouldHide = !exceptId || panelId !== exceptId;
                    if (shouldHide) panel.hidden = true;
                });

                exportHelpToggles.forEach((toggle) => {
                    const toggleId = toggle.dataset.bfcExportHelpToggle || "";
                    const isOpen = exceptId && toggleId === exceptId;
                    toggle.setAttribute(
                        "aria-expanded",
                        isOpen ? "true" : "false",
                    );
                });
            }

            exportHelpToggles.forEach((toggle) => {
                toggle.addEventListener("click", () => {
                    const targetId = toggle.dataset.bfcExportHelpToggle || "";
                    if (!targetId) return;

                    const targetPanel = exportRoot.querySelector(
                        `[data-bfc-export-help="${targetId}"]`,
                    );
                    if (!targetPanel) return;

                    const isOpening = targetPanel.hidden;
                    closeAllExportHelp(isOpening ? targetId : "");
                    targetPanel.hidden = !isOpening;
                });
            });
        }

        applyViewConfig();
        prewarmCoverCache(books);
        render();
        hydrateFromUrlIfNeeded();
    }

    document.querySelectorAll("[data-bfc]").forEach((root) => mount(root));
</script>

<style
    is:global
    is:inline
    data-bfc-style
    media={resolvedConfig.unstyled ? "not all" : "all"}
>
    .bfc_header[hidden],
    .bfc_footer[hidden],
    .bfc_is_hidden {
        display: none !important;
    }

    /* ── Design tokens ───────────────────────────────────────────── */
    .bfc {
        --accent: #d4ff2a;
        --text: #f6f8f4;
        --text-muted: #bbc4b3;
        --text-dim: #c4ccc0;
        --black: oklch(
            4% 0.012 135
        ); /* single dark base — L only varies below */
        --bg-body: var(--black);
        --bg-card: oklch(from var(--black) calc(l + 0.03) c h);
        --bg-input: oklch(from var(--black) calc(l + 0.04) c h);
        --bg-cover: oklch(from var(--black) calc(l + 0.16) c h);
        --border-sub: oklch(from var(--black) calc(l + 0.12) c h);
        --border-card: oklch(from var(--black) calc(l + 0.17) c h);
        --border-input: oklch(from var(--black) calc(l + 0.24) c h);
        --border-link: oklch(from var(--black) calc(l + 0.32) c h);
        --cover-h: clamp(140px, 18vw, 200px);
        --radius: 8px;
        --gap: 16px;
        --padding: 16px; /* base padding unit — all others derived via calc() */
        --font:
            "IBM Plex Mono", "SFMono-Regular", Menlo, Monaco, Consolas,
            monospace;
        --fs-xs: 14px; /* labels, chip, authors, repo link */
        --fs-sm: 15px; /* count, detail body              */
        --fs-md: 16px; /* subtitle, empty state           */
        --fs-lg: 17px; /* (scale step — available)        */
        --fs-xl: clamp(18px, 2vw, 24px); /* card title      */
        --fs-hero: clamp(26px, 5vw, 38px); /* page h1        */

        /* ── Root layout ─────────────────────────────────────────────── */
        max-width: 2560px;
        margin-inline: auto;
        padding-inline: var(--padding);
        padding-block: 24px 48px;
        min-height: 100dvh;
        color: var(--text);
        font-family: var(--font);
    }

    .bfc,
    .bfc * {
        box-sizing: border-box;
    }
    .bfc {
        max-width: 1600px;
        margin-inline: auto;
    }

    .bfc_body {
        background: radial-gradient(
            circle at top right,
            #243410 0%,
            var(--bg-card) 36%,
            var(--bg-body) 100%
        );
        padding: var(--padding);
        border-radius: var(--radius);
    }
    @media (min-width: 1100px) {
        .bfc_body {
            display: grid;
            grid-template-columns: minmax(0, 40fr) minmax(0, 60fr);
            column-gap: 24px;
            align-items: start;
        }
        .bfc_sidebar {
            position: sticky;
            top: 16px;
            align-self: start;
            max-height: calc(100vh - 32px);
            overflow-y: auto;
            padding-inline-end: 8px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .bfc_sidebar::-webkit-scrollbar {
            width: 6px;
        }
        .bfc_sidebar::-webkit-scrollbar-thumb {
            background: var(--border-card);
            border-radius: 3px;
        }
        .bfc_main {
            min-width: 0;
        }

        /* Sidebar: stack every control on its own line */
        .bfc_sidebar .bfc_controls {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .bfc_sidebar .bfc_filter_row {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
            margin-block: 0;
        }
        .bfc_sidebar .bfc_status_tabs {
            flex: 0 0 auto;
        }
        .bfc_sidebar .bfc_lang_filter {
            margin-left: 0;
            flex-direction: column;
            align-items: stretch;
            gap: 6px;
        }
        .bfc_sidebar .bfc_lang_filter select {
            min-block-size: 46px;
            width: 100%;
        }
        .bfc_sidebar .bfc_view_switch,
        .bfc_sidebar .bfc_expand_toggle {
            align-self: flex-start;
        }
    }

    /* ── Header ──────────────────────────────────────────────────── */
    .bfc_header h1 {
        margin-block: 0;
        font-size: clamp(48px, 9vw, 120px);
        font-weight: 100;
        letter-spacing: -0.02em;
        line-height: 0.95;
        color: var(--accent);
        text-wrap: balance;
    }

    .bfc_subtitle {
        margin-block: 8px 0;
        font-size: var(--fs-md);
        color: var(--text-muted);
    }

    .bfc_link {
        font-size: var(--fs-xs);
        color: var(--text);
        text-decoration: none;
        border-block-end: 1px solid var(--border-link);
    }
    .bfc_link:hover {
        color: var(--accent);
        border-color: var(--accent);
    }

    .bfc_footer {
        margin-block-start: var(--padding);
        padding: calc(var(--padding) + 4px) calc(var(--padding) + 2px);
        border-block-start: 1px solid var(--border-sub);
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: flex-start;
        column-gap: 18px;
        row-gap: 12px;
        font-size: var(--fs-xs);
        color: var(--text-muted);
        background-color: black;
        border-radius: var(--radius);
    }

